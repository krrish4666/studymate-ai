# Database
DATABASE_URL=postgresql+asyncpg://user:password@ep-example-123456.us-east-2.aws.neon.tech/studymate?sslmode=require

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# S3-Compatible Storage
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET_NAME=studymate-uploads

# Encryption
ENCRYPTION_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# SMTP (Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend
FRONTEND_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:8000"]

# Environment
ENVIRONMENT=development
DEBUG=true

